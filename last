const App = () => {
  const [gameState, setGameState] = useState('MENU'); 
  const [day, setDay] = useState(1);
  const [resources, setResources] = useState(INITIAL_RESOURCES);
  const [dice, setDice] = useState([]);
  const [selectedDieIndex, setSelectedDieIndex] = useState(null);
  const [currentThreats, setCurrentThreats] = useState([]);
  const [activeDecrees, setActiveDecrees] = useState([]);
  const [log, setLog] = useState([]);
  const [message, setMessage] = useState(null);
  
  // Modal states
  const [showDecreeSelection, setShowDecreeSelection] = useState(false);
  const [decreeOptions, setDecreeOptions] = useState([]);

  // Derived stats based on decrees
  const maxDoom = activeDecrees.find(d => d.id === 'fortification') ? MAX_DOOM + 3 : MAX_DOOM;
  const suppressCost = activeDecrees.find(d => d.id === 'martial_law') ? 2 : 4;
  const freeManaBoost = activeDecrees.find(d => d.id === 'mana_flow');
  const [manaBoostUsed, setManaBoostUsed] = useState(false);

  // --- Core Logic ---

  const startGame = () => {
    setResources(INITIAL_RESOURCES);
    setDay(1);
    setActiveDecrees([]);
    setLog([]);
    setManaBoostUsed(false);
    // 关键修复：强制传入第1天和空法令，避免读取到上一局的旧状态
    startDay(1, []);
  };

  const getThreatCountForDay = (d) => {
    if (d === 1) return 3;
    if (d === 2) return 3;
    if (d === 3) return 4; 
    if (d === 4) return 4;
    if (d >= 5) return 5; 
    return 3;
  };

  // 关键修复：接受当前回合的参数，不再依赖 state
  const getDiceCount = (currentDay, currentDecrees) => {
    let base = 3;
    if (currentDecrees.find(d => d.id === 'lucky_dice')) base += 1;
    // Day 5+ grants an extra die naturally
    if (currentDay >= 5) base += 1;
    return base;
  };

  // 关键修复：允许接受传入的 decrees，默认为 state
  const startDay = (dayNum, currentDecrees = activeDecrees) => {
    setDay(dayNum);
    setManaBoostUsed(false);
    
    // Resources processing (Decrees)
    if (currentDecrees.find(d => d.id === 'tithe')) {
      setResources(prev => ({ ...prev, gold: prev.gold + 3 })); 
      addLog("什一税：获得 3 金币");
    }

    // Generate Dice
    // 关键修复：传入当前的 dayNum 和 currentDecrees
    const count = getDiceCount(dayNum, currentDecrees);
    const newDice = Array(count).fill(0).map((_, i) => ({ 
      id: i, 
      value: Math.floor(Math.random() * 6) + 1,
      modifier: 0, 
      used: false 
    }));
    setDice(newDice);
    
    // Generate Threats
    if (dayNum === MAX_DAYS) {
      setCurrentThreats(BOSS_DECK.map(t => ({ ...t, instanceId: Math.random(), resolved: false })));
      addLog("最终日：天启降临！无法镇压！");
    } else {
      const tCount = getThreatCountForDay(dayNum);
      const threats = [];
      for(let i=0; i<tCount; i++) {
        let pool = THREAT_DECK;
        if (dayNum <= 2) pool = THREAT_DECK.filter(t => t.diff <= 3);
        else if (dayNum <= 4) pool = THREAT_DECK.filter(t => t.diff <= 5);
        else pool = THREAT_DECK.filter(t => t.diff >= 4); 

        const t = pool[Math.floor(Math.random() * pool.length)];
        threats.push({ ...t, instanceId: Math.random(), resolved: false });
      }
      setCurrentThreats(threats);
      addLog(`第 ${dayNum} 天：出现了 ${tCount} 个危机。`);
    }
    
    setSelectedDieIndex(null);
    setGameState('PLAYING');
  };

  const rollDie = () => Math.floor(Math.random() * 6) + 1;

  const rerollDie = () => {
    if (selectedDieIndex === null) return showMessage("请先选择骰子", "error");
    if (resources.gold < 3) return showMessage("金币不足 (3)", "error");

    setResources(prev => ({ ...prev, gold: prev.gold - 3 }));
    setDice(prev => prev.map((d, i) => i === selectedDieIndex ? { ...d, value: rollDie() } : d));
    showMessage("重随成功", "success");
  };

  const boostDie = (amount) => {
    if (selectedDieIndex === null) return showMessage("请先选择骰子", "error");
    
    // Check Mana Flow perk
    if (freeManaBoost && !manaBoostUsed) {
      setManaBoostUsed(true);
      showMessage("法力回流触发 (免费)", "success");
    } else {
      if (resources.magic < 2) return showMessage("魔力不足 (2)", "error");
      setResources(prev => ({ ...prev, magic: prev.magic - 2 }));
      showMessage("魔力增幅 +1", "success");
    }

    setDice(prev => prev.map((d, i) => 
      i === selectedDieIndex ? { ...d, modifier: d.modifier + amount } : d
    ));
  };

  const buyDoomReduction = () => {
    const hasPerk = activeDecrees.find(d => d.id === 'black_market');
    if (!hasPerk) return;
    if (resources.gold < 5) return showMessage("金币不足", "error");
    if (resources.doom <= 0) return showMessage("没有毁灭值可消除", "info");

    setResources(prev => ({ ...prev, gold: prev.gold - 5, doom: Math.max(0, prev.doom - 1) }));
    showMessage("黑市交易完成", "success");
  };

  const handleSuppress = (threat) => {
    if (threat.immuneToSuppress) return showMessage("此危机无法被镇压！", "error");
    if (resources.army < suppressCost) return showMessage(`军力不足 (${suppressCost})`, "error");
    
    setResources(prev => ({ ...prev, army: prev.army - suppressCost }));
    
    const newThreats = currentThreats.map(t => 
      t.instanceId === threat.instanceId ? { ...t, resolved: true } : t
    );
    setCurrentThreats(newThreats);
    addLog(`镇压了 ${threat.title}`);
  };

  const assignDieToThreat = (threat) => {
    if (selectedDieIndex === null) return;
    
    const die = dice[selectedDieIndex];
    const finalVal = die.value + die.modifier;
    const isSuccess = finalVal >= threat.diff;
    
    const newResources = { ...resources };
    let logMsg = "";
    let doomAdded = 0;

    if (isSuccess) {
      if (threat.goodReward.gold) newResources.gold += threat.goodReward.gold;
      if (threat.goodReward.magic) newResources.magic += threat.goodReward.magic;
      if (threat.goodReward.army) newResources.army += threat.goodReward.army;
      if (threat.goodReward.doom) newResources.doom += threat.goodReward.doom; // Usually negative
      logMsg = `解决: ${threat.title}`;
      showMessage("胜利", "success");
    } else {
      if (threat.badEffect.doom) {
         doomAdded = threat.badEffect.doom;
      }
      if (threat.badEffect.gold) newResources.gold += threat.badEffect.gold;
      if (threat.badEffect.army) newResources.army += threat.badEffect.army;
      if (threat.badEffect.magic) newResources.magic += threat.badEffect.magic;
      logMsg = `失败: ${threat.title}`;
      showMessage("溃败", "error");
    }

    // 3.0 Mechanic: Resource Debt converts to Doom
    ['gold', 'army', 'magic'].forEach(res => {
      if (newResources[res] < 0) {
        const debt = Math.abs(newResources[res]);
        doomAdded += debt;
        addLog(`资源匮乏: ${debt} 点 ${res} 转化为毁灭值!`);
        newResources[res] = 0;
      }
    });

    // Propaganda perk check
    if (doomAdded > 0 && activeDecrees.find(d => d.id === 'propaganda')) {
      if (Math.random() > 0.5) {
        doomAdded = 0;
        showMessage("虚假宣传生效！毁灭值被掩盖。", "success");
      }
    }

    newResources.doom += doomAdded;
    setResources(newResources);
    addLog(logMsg);
    
    // Cleanup
    const newDice = [...dice];
    newDice[selectedDieIndex].used = true;
    setDice(newDice);
    setSelectedDieIndex(null);

    const newThreats = currentThreats.map(t => 
      t.instanceId === threat.instanceId ? { ...t, resolved: true } : t
    );
    setCurrentThreats(newThreats);

    if (newResources.doom >= maxDoom) setGameState('GAMEOVER');
  };

  const endDay = () => {
    // Resolve unresolved threats
    const unresolved = currentThreats.filter(t => !t.resolved);
    let newRes = { ...resources };
    let totalDoomAdded = 0;

    unresolved.forEach(t => {
      if (t.badEffect.doom) totalDoomAdded += t.badEffect.doom;
      if (t.badEffect.gold) newRes.gold += t.badEffect.gold;
      if (t.badEffect.army) newRes.army += t.badEffect.army;
      if (t.badEffect.magic) newRes.magic += t.badEffect.magic;
    });

    // Resource Debt Check again
    ['gold', 'army', 'magic'].forEach(res => {
      if (newRes[res] < 0) {
        totalDoomAdded += Math.abs(newRes[res]);
        newRes[res] = 0;
      }
    });

    if (totalDoomAdded > 0) addLog(`无视危机/资源赤字: 毁灭值 +${totalDoomAdded}`);
    newRes.doom += totalDoomAdded;
    setResources(newRes);

    if (newRes.doom >= maxDoom) {
      setGameState('GAMEOVER');
      return;
    }

    if (day >= MAX_DAYS) {
      setGameState('VICTORY');
    } else {
      // Trigger Decree Selection on Day 2 and 4
      if (day === 2 || day === 4) {
        triggerDecreeSelection();
      } else {
        startDay(day + 1);
      }
    }
  };

  const triggerDecreeSelection = () => {
    // Pick 3 random perks that aren't already active
    const available = DECREES.filter(d => !activeDecrees.find(ad => ad.id === d.id));
    const shuffled = [...available].sort(() => 0.5 - Math.random());
    setDecreeOptions(shuffled.slice(0, 3));
    setShowDecreeSelection(true);
  };

  const selectDecree = (decree) => {
    setActiveDecrees([...activeDecrees, decree]);
    setShowDecreeSelection(false);
    addLog(`颁布新法: ${decree.title}`);
    startDay(day + 1);
  };

  // Helper
  const addLog = (msg) => setLog(prev => [msg, ...prev].slice(0, 5));
  const showMessage = (text, type) => {
    setMessage({ text, type });
    setTimeout(() => setMessage(null), 1500);
  };

  // --- Render ---

  if (gameState === 'MENU') {
    return (
      <div className="min-h-screen bg-gray-950 flex flex-col items-center justify-center text-gray-100 font-sans p-4 relative overflow-hidden">
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-amber-900/20 via-gray-900 to-gray-950"></div>
        <div className="text-center space-y-8 max-w-lg w-full relative z-10">
          <div className="flex justify-center mb-4">
             <Crown size={80} className="text-amber-500 animate-bounce" />
          </div>
          <div>
            <h1 className="text-6xl font-black text-white mb-2 tracking-tighter drop-shadow-xl">王国的<br/><span className="text-amber-600">最后七天</span></h1>
            <div className="flex justify-center gap-2 text-amber-500/60 text-sm font-bold tracking-[0.3em] uppercase">
              <span>策略</span> &bull; <span>生存</span> &bull; <span>博弈</span>
            </div>
          </div>
          
          <div className="bg-gray-900/80 backdrop-blur p-6 rounded-xl border border-gray-800 text-left space-y-4 text-sm text-gray-300 shadow-2xl">
            <h3 className="text-white font-bold text-lg border-b border-gray-700 pb-2 mb-4">V3.7.1 Bug修复版</h3>
            <ul className="space-y-3">
              <li className="flex items-start gap-2"><RefreshCw className="text-yellow-400 shrink-0" size={16} /> <span><b>经济刺激：</b> 初始资源大幅提升，技能消耗降低。</span></li>
              <li className="flex items-start gap-2"><Shield className="text-green-400 shrink-0" size={16} /> <span><b>难度回调：</b> 天启骑士不再是不可战胜的，只要善用魔力。</span></li>
              <li className="flex items-start gap-2"><Ban className="text-rose-500 shrink-0" size={16} /> <span><b>核心规则：</b> 依然小心资源赤字，那是通往毁灭的捷径。</span></li>
            </ul>
          </div>

          <button onClick={startGame} className="w-full bg-amber-700 hover:bg-amber-600 text-white font-bold py-4 px-12 rounded-xl text-xl transition-all shadow-[0_0_30px_rgba(180,83,9,0.4)] hover:scale-[1.02] border-t border-amber-500">
            开始统治
          </button>
        </div>
      </div>
    );
  }

  if (gameState === 'GAMEOVER') {
    return (
      <div className="min-h-screen bg-red-950 flex flex-col items-center justify-center text-gray-100 p-4 text-center relative">
        <div className="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/dark-matter.png')] opacity-50"></div>
        <div className="z-10 max-w-lg">
          <Skull size={100} className="text-red-500 mb-6 mx-auto animate-pulse" />
          <h2 className="text-5xl font-black text-white mb-4 tracking-widest uppercase">王国陨落</h2>
          <p className="text-red-200 text-xl mb-8 leading-relaxed">
            历史不会记住弱者。<br/>毁灭值达到了 {resources.doom} / {maxDoom}。
          </p>
          <button onClick={() => setGameState('MENU')} className="bg-white text-red-900 font-bold py-3 px-12 rounded hover:bg-gray-200 shadow-xl hover:scale-105 transition-transform">
            重新开始
          </button>
        </div>
      </div>
    );
  }

  if (gameState === 'VICTORY') {
    return (
      <div className="min-h-screen bg-amber-950 flex flex-col items-center justify-center text-gray-100 p-4 text-center relative">
        <div className="absolute inset-0 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-yellow-600/20 via-amber-950 to-black"></div>
        <div className="z-10 max-w-lg">
          <Crown size={100} className="text-yellow-400 mb-6 mx-auto" />
          <h2 className="text-5xl font-black text-white mb-4">光荣的胜利</h2>
          <p className="text-amber-100 text-xl mb-8">
            你在天启中幸存了下来。<br/>你的法令被后世传颂。
          </p>
          <div className="flex justify-center gap-2 mb-8 flex-wrap">
            {activeDecrees.map(d => (
              <span key={d.id} className="text-xs bg-black/40 px-3 py-1 rounded-full border border-amber-500/30 text-amber-200">{d.title}</span>
            ))}
          </div>
          <button onClick={() => setGameState('MENU')} className="bg-amber-500 text-white font-bold py-3 px-12 rounded hover:bg-amber-400 shadow-xl hover:scale-105 transition-transform">
            再次统治
          </button>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gray-950 text-gray-100 flex flex-col font-sans select-none overflow-hidden relative">
      
      {/* Decree Modal */}
      {showDecreeSelection && <DecreeModal options={decreeOptions} onSelect={selectDecree} />}

      {/* HUD */}
      <header className="bg-gray-900 border-b border-gray-800 p-3 z-20 shadow-md relative">
        <div className="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-3">
          
          <div className="flex items-center gap-4 w-full md:w-auto justify-between md:justify-start">
            <div className="flex flex-col items-center bg-gray-800 px-3 py-1 rounded border border-gray-700">
              <span className="text-[10px] text-gray-400 font-bold uppercase tracking-wider">Day</span>
              <span className={`text-2xl font-black leading-none ${day === 7 ? 'text-red-500 animate-pulse' : 'text-white'}`}>{day}/{MAX_DAYS}</span>
            </div>
            
            <div className="flex items-center gap-2 bg-red-950/30 px-3 py-2 rounded border border-red-900/50 flex-1 md:flex-none min-w-[140px]">
               <AlertTriangle size={16} className="text-red-500" />
               <div className="flex flex-col w-full">
                 <div className="flex justify-between text-[10px] font-bold uppercase tracking-widest text-red-400 mb-1">
                   <span>毁灭值</span>
                   <span>{resources.doom}/{maxDoom}</span>
                 </div>
                 <div className="h-2 bg-gray-800 rounded-full overflow-hidden">
                   <div className="h-full bg-red-600 transition-all duration-500" style={{ width: `${(resources.doom / maxDoom) * 100}%` }}></div>
                 </div>
               </div>
            </div>
          </div>

          {/* Feedback Message */}
          <div className="absolute top-20 left-1/2 transform -translate-x-1/2 pointer-events-none z-50">
             {message && (
               <div className={`px-6 py-3 rounded-xl shadow-2xl font-black backdrop-blur-md border animate-in fade-in zoom-in duration-200 flex items-center gap-2
                 ${message.type === 'success' ? 'bg-green-900/90 text-green-100 border-green-500' : 'bg-red-900/90 text-red-100 border-red-500'}
               `}>
                 {message.type === 'success' ? <Shield size={18}/> : <Skull size={18}/>}
                 {message.text}
               </div>
             )}
          </div>

          {/* Resources */}
          <div className="flex gap-2 w-full md:w-auto justify-center">
            <ResourceBadge icon={Coins} value={resources.gold} label="金币" color="text-yellow-400" danger={resources.gold <= 2} />
            <ResourceBadge icon={Swords} value={resources.army} label="军力" color="text-blue-400" danger={resources.army <= 2} />
            <ResourceBadge icon={Zap} value={resources.magic} label="魔力" color="text-purple-400" danger={resources.magic <= 2} />
          </div>
        </div>
      </header>

      {/* Active Decrees Bar */}
      {activeDecrees.length > 0 && (
        <div className="bg-black/20 border-b border-white/5 py-1 px-4 flex justify-center gap-4 overflow-x-auto">
          {activeDecrees.map(d => {
            const Icon = d.icon;
            return (
              <div key={d.id} className="flex items-center gap-1.5 text-xs text-gray-400" title={d.desc}>
                <Icon size={12} className={d.color} />
                <span>{d.title}</span>
              </div>
            )
          })}
        </div>
      )}

      {/* Main Game Area */}
      <main className="flex-1 overflow-y-auto p-4 max-w-6xl mx-auto w-full flex flex-col pb-40">
        
        {/* Boss Warning */}
        {day === 7 && (
          <div className="mb-6 bg-rose-950/50 border border-rose-500/50 p-4 rounded-lg text-center animate-pulse">
             <h3 className="text-rose-400 font-black text-xl tracking-[0.3em] uppercase mb-1">决战时刻</h3>
             <p className="text-rose-200/60 text-xs">BOSS 无法被军队镇压，但你可以利用魔力强化骰子击败它。</p>
          </div>
        )}

        {/* Cards Grid */}
        <div className={`grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4`}>
          {currentThreats.map((threat) => (
            <ThreatCard 
              key={threat.instanceId} 
              threat={threat} 
              onAssign={assignDieToThreat}
              onSuppress={handleSuppress}
              selectedDie={selectedDieIndex !== null ? dice[selectedDieIndex] : null}
              canAffordArmy={resources.army >= suppressCost}
              suppressCost={suppressCost}
            />
          ))}
        </div>

      </main>

      {/* Footer Controls */}
      <div className="fixed bottom-0 left-0 right-0 bg-[#0f1117] border-t border-gray-800 p-4 pb-6 shadow-[0_-10px_40px_rgba(0,0,0,0.8)] z-30">
        <div className="max-w-6xl mx-auto flex flex-col md:flex-row items-end md:items-center justify-between gap-4">
          
          {/* Skills */}
          <div className="flex gap-2 w-full md:w-auto justify-center order-2 md:order-1">
            <button onClick={rerollDie} className="flex flex-col items-center gap-1 group p-2 rounded-lg hover:bg-white/5 transition-colors">
              <div className="w-10 h-10 rounded-full bg-gray-800 border border-gray-600 flex items-center justify-center text-yellow-500 group-hover:bg-yellow-500 group-hover:text-white transition-all shadow-lg">
                <RefreshCw size={18} />
              </div>
              <span className="text-[10px] text-gray-400 font-bold">-3 金币</span>
            </button>

             <button onClick={() => boostDie(1)} className="flex flex-col items-center gap-1 group p-2 rounded-lg hover:bg-white/5 transition-colors">
              <div className={`w-10 h-10 rounded-full bg-gray-800 border border-gray-600 flex items-center justify-center group-hover:bg-purple-600 group-hover:text-white transition-all shadow-lg ${freeManaBoost && !manaBoostUsed ? 'text-green-400 border-green-500' : 'text-purple-500'}`}>
                <Zap size={18} />
              </div>
              <span className="text-[10px] text-gray-400 font-bold">{freeManaBoost && !manaBoostUsed ? '免费' : '-2 魔力'}</span>
            </button>

            {activeDecrees.find(d => d.id === 'black_market') && (
              <button onClick={buyDoomReduction} className="flex flex-col items-center gap-1 group p-2 rounded-lg hover:bg-white/5 transition-colors">
                <div className="w-10 h-10 rounded-full bg-gray-800 border border-gray-600 flex items-center justify-center text-green-500 group-hover:bg-green-600 group-hover:text-white transition-all shadow-lg">
                  <Ghost size={18} />
                </div>
                <span className="text-[10px] text-gray-400 font-bold">-5 金 / 减毁</span>
              </button>
            )}
          </div>

          {/* Dice Pool */}
          <div className="flex-1 flex justify-center gap-3 order-1 md:order-2 w-full pb-2 md:pb-0 border-b md:border-none border-gray-800">
            {dice.map((die, idx) => !die.used && (
              <Die 
                key={die.id} 
                value={die.value} 
                modifier={die.modifier}
                isSelected={selectedDieIndex === idx} 
                onClick={() => setSelectedDieIndex(selectedDieIndex === idx ? null : idx)}
              />
            ))}
            {dice.every(d => d.used) && (
              <div className="text-gray-600 font-bold text-sm italic flex items-center animate-pulse">
                行动点数耗尽，请结束回合...
              </div>
            )}
          </div>

          {/* End Turn */}
          <div className="order-3 md:order-3 w-full md:w-auto">
             <button 
              onClick={endDay}
              className={`
                w-full md:w-auto px-8 py-4 rounded-xl font-black uppercase tracking-wider flex items-center justify-center gap-2 shadow-xl transition-all hover:scale-105
                ${dice.some(d => !d.used) && currentThreats.some(t => !t.resolved)
                  ? 'bg-gray-800 text-red-400 border-2 border-red-900 hover:bg-red-900 hover:text-white' 
                  : 'bg-gradient-to-r from-amber-700 to-orange-700 text-white border-t border-orange-500'
                }
              `}
            >
              <span className="text-sm">
                {dice.some(d => !d.used) && currentThreats.some(t => !t.resolved) ? "强行结束 (承受惩罚)" : "进入下一天"}
              </span>
              <ArrowRight size={18} />
            </button>
          </div>

        </div>
        
        {/* Log */}
        <div className="text-center text-[10px] text-gray-600 mt-2 h-4 overflow-hidden font-mono uppercase tracking-wide">
          {log[0] || "等待指令..."}
        </div>
      </div>
    </div>
  );
};

export default App;
