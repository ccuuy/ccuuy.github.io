const ResourceBadge = ({ icon: Icon, value, label, color = "text-gray-200", danger }) => (
  <div className={`flex items-center gap-2 px-3 py-2 rounded border shadow-sm min-w-[80px] justify-center transition-all duration-300 ${danger ? 'bg-red-900/50 border-red-500 scale-110 animate-pulse' : 'bg-gray-900/80 border-gray-700'}`}>
    <Icon size={16} className={color} />
    <span className={`text-sm font-bold ${value < 0 ? 'text-red-500' : 'text-gray-200'}`}>{value}</span>
  </div>
);

const Die = ({ value, isSelected, onClick, disabled, modifier = 0 }) => {
  const finalValue = value + modifier;
  let displayValue = finalValue;
  if (displayValue > 99) displayValue = 99; 
  if (displayValue < 1) displayValue = 1;

  return (
    <button
      onClick={onClick}
      disabled={disabled}
      className={`
        relative w-16 h-16 rounded-xl text-3xl font-black flex items-center justify-center border-b-4 transition-all transform
        ${isSelected 
          ? 'bg-amber-500 text-white border-amber-700 translate-y-1 shadow-inner' 
          : disabled 
            ? 'bg-gray-800 text-gray-600 border-gray-900 cursor-not-allowed opacity-50'
            : 'bg-gray-200 text-gray-800 border-gray-400 hover:-translate-y-1 hover:shadow-lg'
        }
      `}
    >
      {displayValue}
      {modifier !== 0 && (
        <div className="absolute -top-2 -right-2 flex flex-col gap-0.5">
          <span className={`text-[10px] px-1.5 py-0.5 rounded-full font-bold shadow border ${modifier > 0 ? 'bg-purple-600 text-white border-purple-400' : 'bg-red-600 text-white border-red-400'}`}>
            {modifier > 0 ? '+' : ''}{modifier}
          </span>
        </div>
      )}
    </button>
  );
};

const ThreatCard = ({ threat, onAssign, onSuppress, selectedDie, canAffordArmy, suppressCost }) => {
  const typeInfo = THREAT_TYPES[threat.type];
  const Icon = typeInfo.icon;
  
  let outcome = "neutral"; 
  let finalDieVal = 0;
  
  if (selectedDie) {
    finalDieVal = selectedDie.value + selectedDie.modifier;
    if (finalDieVal >= threat.diff) outcome = "success";
    else outcome = "fail";
  }

  return (
    <div className={`
      relative flex flex-col bg-gray-800 rounded-lg border-2 p-4 transition-all duration-300 h-full group
      ${threat.resolved ? 'opacity-30 scale-95 grayscale border-gray-800' : `${typeInfo.borderColor} shadow-lg hover:shadow-xl hover:-translate-y-1`}
      ${selectedDie && !threat.resolved ? (outcome === 'success' ? 'ring-4 ring-green-500/50' : 'ring-4 ring-red-500/50') : ''}
    `}>
      {/* Header */}
      <div className="flex justify-between items-start mb-3 pb-2 border-b border-gray-700/50">
        <div className="flex items-center gap-2">
          <div className={`p-1.5 rounded bg-gray-900 ${typeInfo.color}`}>
            <Icon size={18} />
          </div>
          <h3 className={`font-bold leading-tight ${typeInfo.color}`}>{threat.title}</h3>
        </div>
        <div className="flex flex-col items-end">
           <div className="text-xs font-mono text-gray-500 uppercase">Diff</div>
           <div className={`text-xl font-black ${threat.diff > 6 ? 'text-red-500' : 'text-white'}`}>{threat.diff}</div>
        </div>
      </div>

      {/* Description */}
      <p className="text-xs text-gray-400 mb-4 flex-grow leading-relaxed">{threat.desc}</p>

      {/* Rewards/Penalties */}
      <div className="space-y-2 text-xs mb-4 bg-black/30 p-3 rounded border border-white/5">
        <div className="flex items-center justify-between text-green-400/90">
          <span className="font-bold opacity-70">成功:</span>
          <div className="flex gap-2 font-mono">
            {threat.goodReward.gold && <span>+{threat.goodReward.gold}金</span>}
            {threat.goodReward.magic && <span>+{threat.goodReward.magic}魔</span>}
            {threat.goodReward.army && <span>+{threat.goodReward.army}兵</span>}
            {threat.goodReward.doom && <span className="text-blue-300">{threat.goodReward.doom}毁灭</span>}
          </div>
        </div>
        <div className="flex items-center justify-between text-red-400/90">
          <span className="font-bold opacity-70">失败:</span>
          <div className="flex gap-2 font-mono">
            {threat.badEffect.doom && <span className="font-bold text-red-500">+{threat.badEffect.doom}毁灭</span>}
            {threat.badEffect.gold && <span>{threat.badEffect.gold}金</span>}
            {threat.badEffect.army && <span>{threat.badEffect.army}兵</span>}
            {threat.badEffect.magic && <span>{threat.badEffect.magic}魔</span>}
          </div>
        </div>
      </div>

      {/* Actions */}
      {!threat.resolved ? (
        <div className="space-y-2 mt-auto">
          <button
            onClick={() => onAssign(threat)}
            disabled={!selectedDie}
            className={`
              w-full py-3 rounded font-bold text-sm transition-all flex items-center justify-center gap-2 border
              ${selectedDie 
                ? (outcome === 'success' 
                    ? 'bg-green-700 hover:bg-green-600 text-white border-green-500' 
                    : 'bg-red-900/80 hover:bg-red-800 text-red-100 border-red-700')
                : 'bg-gray-700 text-gray-500 border-gray-600 cursor-default'
              }
            `}
          >
            {selectedDie ? (
              outcome === 'success' ? (
                <>
                  <Shield size={16} /> 必胜 ({finalDieVal})
                </>
              ) : (
                <>
                  <AlertTriangle size={16} /> 失败 ({finalDieVal})
                </>
              )
            ) : (
              <span className="text-xs opacity-50">选择骰子</span>
            )}
          </button>

          {threat.immuneToSuppress ? (
             <div className="w-full py-2 rounded text-xs font-bold flex items-center justify-center gap-1 bg-gray-900/50 text-gray-500 border border-gray-800 cursor-not-allowed opacity-70">
               <Ban size={12} /> 天启无法镇压
             </div>
          ) : (
            <button
              onClick={() => onSuppress(threat)}
              disabled={!canAffordArmy}
              className={`
                w-full py-2 rounded text-xs font-bold flex items-center justify-center gap-1 transition-all border border-dashed
                ${canAffordArmy 
                  ? 'bg-gray-800 text-blue-300 border-blue-800 hover:bg-blue-900/50 hover:border-blue-400' 
                  : 'bg-gray-900 text-gray-600 border-gray-800 cursor-not-allowed'
                }
              `}
              title={`消耗 ${suppressCost} 军力直接解决`}
            >
              <Gavel size={12} /> 镇压 (-{suppressCost} 军力)
            </button>
          )}
        </div>
      ) : (
        <div className="mt-auto h-16 flex items-center justify-center border-2 border-dashed border-gray-700 rounded bg-gray-800/50">
